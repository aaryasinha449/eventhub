# EventHub backend environment
NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://localhost:27017/eventhub
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

CORS_ORIGIN=http://localhost:5173

# Optional providers
STRIPE_SECRET_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@eventhub.io
